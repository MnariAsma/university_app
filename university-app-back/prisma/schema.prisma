// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  STUDENT
  TEACHER
}

enum CourseType {
  COURSE
  TD
  TP
}

enum SessionType {
  COURSE
  TD
  TP
  EXAM
}

enum AbsenceStatus {
  ABSENT
  PRESENT
  EXCUSED
}

enum ExamStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum EventType {
  START_OF_YEAR
  HOLIDAY
  EXAM
  MAKEUP
  OTHER
}

enum GradeStatus {
  PROVISIONAL
  FINAL
}

// ============================================================
// AUTHENTICATION & USERS
// ============================================================

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  role       Role
  firstName  String
  lastName   String
  phone      String?
  photo      String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student    Student?
  teacher    Teacher?
  admin      Admin?

  notifications Notification[]
  @@map("users")
}

// ============================================================
// ADMIN
// ============================================================

model Admin {
  id            String      @id @default(cuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  news          News[]
  exams         Exam[]
  sessions      Session[]
  calendarEvents CalendarEvent[]

  @@map("admins")
}

// ============================================================
// ACADEMIC YEAR
// ============================================================

model AcademicYear {
  id        String   @id @default(cuid())
  label     String   @unique // ex: "2023-2024"
  startDate DateTime
  endDate   DateTime
  active    Boolean  @default(false)
  createdAt DateTime @default(now())

  students        Student[]
  teacherSubjects TeacherSubject[]
  grades          Grade[]
  exams           Exam[]

  @@map("academic_years")
}

// ============================================================
// UNIVERSITY STRUCTURE
// ============================================================

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  programs    Program[]
  teachers    Teacher[]
  students    Student[]
  news        News[]

  @@map("departments")
}

model Program {
  id            String      @id @default(cuid())
  name          String      // Filière, ex: "Ingénierie Informatique"
  code          String      @unique
  description   String?
  level         String      
  departmentId  String
  department    Department  @relation(fields: [departmentId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  levels        Level[]
  subjects      Subject[]
  students      Student[]
  exams         Exam[]
  news          News[]

  @@map("programs")
}

model Level {
  id         String  @id @default(cuid())
  name       String 
  order      Int

  programId  String
  program    Program @relation(fields: [programId], references: [id])

  groups     Group[]

  @@map("levels")
}

model Group {
  id        String  @id @default(cuid())
  name      String
  code      String  @unique

  levelId   String
  level     Level   @relation(fields: [levelId], references: [id])

  students  Student[]
  sessions  Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("groups")
}

// ============================================================
// STUDENT
// ============================================================

model Student {
  id            String      @id @default(cuid())
  matricule     String      @unique
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId  String
  department    Department  @relation(fields: [departmentId], references: [id])
  programId     String
  program       Program     @relation(fields: [programId], references: [id])
  groupId       String
  group         Group       @relation(fields: [groupId], references: [id])
  
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  absences      Absence[]
  grades        Grade[]
  examRegs      ExamRegistration[]

  @@map("students")
}

// ============================================================
// TEACHER
// ============================================================

model Teacher {
  id            String      @id @default(cuid())
  matricule     String      @unique
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId  String
  department    Department  @relation(fields: [departmentId], references: [id])
  grade         String?
  specialty     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  courses       Course[]
  sessions      Session[]
  subjectLinks  TeacherSubject[]
  grades        Grade[]
  exams         Exam[]

  @@map("teachers")
}

// ============================================================
// SUBJECTS
// ============================================================

model Subject {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  description   String?
  coefficient   Float    @default(1)
  hours         Int?
  programId     String
  program       Program  @relation(fields: [programId], references: [id])
  semester      Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  teachers      TeacherSubject[]
  courses       Course[]
  sessions      Session[]
  absences      Absence[]
  grades        Grade[]
  exams         Exam[]

  @@map("subjects")
}

model TeacherSubject {
  id              String       @id @default(cuid())
  subjectId       String
  subject         Subject      @relation(fields: [subjectId], references: [id])
  teacherId       String
  teacher         Teacher      @relation(fields: [teacherId], references: [id])
  courseType      CourseType   @default(COURSE)
  
  academicYearId  String
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([subjectId, teacherId, courseType, academicYearId])
  @@map("teacher_subjects")
}

// ============================================================
// COURSES
// ============================================================

model Course {
  id           String     @id @default(cuid())
  title        String
  description  String?
  content      String?
  fileUrl      String?
  type         CourseType @default(COURSE)
  subjectId    String
  subject      Subject    @relation(fields: [subjectId], references: [id])
  teacherId    String
  teacher      Teacher    @relation(fields: [teacherId], references: [id])
  published    Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("courses")
}

// ============================================================
// SCHEDULE
// ============================================================

model Room {
  id       String  @id @default(cuid())
  name     String  @unique
  capacity Int?
  building String?

  sessions Session[]
  exams    Exam[]

  @@map("rooms")
}

model Session {
  id           String     @id @default(cuid())
  title        String?
  type         SessionType @default(COURSE)
  subjectId    String
  subject      Subject    @relation(fields: [subjectId], references: [id])
  teacherId    String
  teacher      Teacher    @relation(fields: [teacherId], references: [id])
  groupId      String
  group        Group      @relation(fields: [groupId], references: [id])
  roomId       String?
  room         Room?      @relation(fields: [roomId], references: [id])
  adminId      String     
  admin        Admin      @relation(fields: [adminId], references: [id])
  startDate    DateTime
  endDate      DateTime
  recurring    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  absences     Absence[]

  @@map("sessions")
}

// ============================================================
// ABSENCES
// ============================================================

model Absence {
  id            String         @id @default(cuid())
  studentId     String
  student       Student        @relation(fields: [studentId], references: [id])
  subjectId     String
  subject       Subject        @relation(fields: [subjectId], references: [id])
  sessionId     String
  session       Session        @relation(fields: [sessionId], references: [id])
  status        AbsenceStatus  @default(ABSENT)
  justification String?
  justified     Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([studentId, sessionId])
  @@map("absences")
}

// ============================================================
// GRADES
// ============================================================

model Grade {
  id             String       @id @default(cuid())
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  subjectId      String
  subject        Subject      @relation(fields: [subjectId], references: [id])
  teacherId      String
  teacher        Teacher      @relation(fields: [teacherId], references: [id])
  examId         String?
  exam           Exam?        @relation(fields: [examId], references: [id])
  value          Float
  evaluationType String
  status         GradeStatus  @default(PROVISIONAL)
  comment        String?
  
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  semester       Int
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("grades")
}

// ============================================================
// EXAMS
// ============================================================

model Exam {
  id             String       @id @default(cuid())
  title          String
  description    String?
  subjectId      String
  subject        Subject      @relation(fields: [subjectId], references: [id])
  programId      String
  program        Program      @relation(fields: [programId], references: [id])
  adminId        String
  admin          Admin        @relation(fields: [adminId], references: [id])
  teacherId      String?
  teacher        Teacher?     @relation(fields: [teacherId], references: [id])
  roomId         String?
  room           Room?        @relation(fields: [roomId], references: [id])
  startDate      DateTime
  endDate        DateTime
  status         ExamStatus   @default(SCHEDULED)
  semester       Int
  
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  registrations  ExamRegistration[]
  grades         Grade[]

  @@map("exams")
}

model ExamRegistration {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  examId    String
  exam      Exam     @relation(fields: [examId], references: [id])
  createdAt DateTime @default(now())

  @@unique([studentId, examId])
  @@map("exam_registrations")
}

// ============================================================
// NEWS
// ============================================================

model News {
  id            String      @id @default(cuid())
  title         String
  content       String
  imageUrl      String?
  adminId       String
  admin         Admin       @relation(fields: [adminId], references: [id])
  published     Boolean     @default(true)
  
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  programId     String?
  program       Program?    @relation(fields: [programId], references: [id])

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("news")
}

// ============================================================
// CALENDAR
// ============================================================

model CalendarEvent {
  id          String      @id @default(cuid())
  title       String
  description String?
  type        EventType   @default(OTHER)
  startDate   DateTime
  endDate     DateTime
  adminId     String
  admin       Admin       @relation(fields: [adminId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("calendar_events")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

enum NotificationType {
  INFO
  ALERT
  REMINDER
  GRADE
  ABSENCE
  COURSE
  EXAM
}

model Notification {
  id              String           @id @default(cuid())
  title           String
  message         String
  type            NotificationType @default(INFO)
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  read            Boolean          @default(false)
  redirectLink    String?
  createdAt       DateTime         @default(now())

  @@map("notifications")
}